---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="cols">
      <div>
        <div class="logo" style="display:flex;align-items:center;gap:10px;font-weight:800;font-size:19px;"><span class="box" style="width:30px;height:30px;border-radius:8px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;">✓</span> Checklist</div>
        <p style="max-width:280px;color:#a3a29f;">Free, professional checklist templates to organize your life &amp; work. Download, customize and get things done.</p>
      </div>
      <div>
        <h4>Product</h4>
        <ul>
          <li><a href="/templates">Templates</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
      <div>
        <h4>Categories</h4>
        <ul>
          <li><a href="/templates?cat=business">Business</a></li>
          <li><a href="/templates?cat=personal">Personal</a></li>
          <li><a href="/templates?cat=travel">Travel</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <span>© {year} Checklist. All rights reserved.</span>
      <span>Made with ❤️ for productivity.</span>
    </div>
  </div>
</footer>
