---
import { site } from '../config/site';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
const s = site.social;
const socials = [
  { url: s.instagram, label: 'Instagram', icon: 'instagram' },
  { url: s.whatsapp, label: 'WhatsApp', icon: 'message' },
  { url: s.telegram, label: 'Telegram', icon: 'send' },
  { url: s.youtube, label: 'YouTube', icon: 'youtube' },
].filter(x => x.url);
---
<footer class="footer">
  <div class="container">
    <div class="cols">
      <div>
        <div class="logo" style="display:flex;align-items:center;gap:10px;font-weight:800;font-size:19px;color:#fff;"><span class="box" style="width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--blue),var(--accent2));color:#fff;display:flex;align-items:center;justify-content:center;"><Icon name="check" size={18} sw={3} /></span> {site.name}</div>
        <p style="max-width:300px;color:#a3a29f;margin-top:10px;">{site.shortDescription}</p>
        {socials.length > 0 && (
          <div style="display:flex;gap:10px;margin-top:14px;">
            {socials.map(x => (
              <a href={x.url} target="_blank" rel="noopener" aria-label={x.label} title={x.label} style="width:38px;height:38px;border-radius:9px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;color:#e8e8e6;"><Icon name={x.icon} size={18} /></a>
            ))}
          </div>
        )}
      </div>
      <div>
        <h4 data-i18n="foot_product">Product</h4>
        <ul>
          <li><a href="/maker" data-i18n="nav_maker">Template Maker</a></li>
          <li><a href="/templates" data-i18n="nav_templates">Templates</a></li>
          <li><a href="/blog" data-i18n="nav_blog">Blog</a></li>
          <li><a href="/about" data-i18n="foot_about">About</a></li>
        </ul>
      </div>
      <div>
        <h4 data-i18n="foot_categories">Categories</h4>
        <ul>
          <li><a href="/templates">Business</a></li>
          <li><a href="/templates">Personal</a></li>
          <li><a href="/templates">Travel</a></li>
        </ul>
      </div>
      <div>
        <h4 data-i18n="foot_legal">Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="bottom">
      <span>© {year} <a href={site.credit.url}>{site.credit.text}</a>. All rights reserved.</span>
      <span>{site.tagline}</span>
    </div>
  </div>
</footer>
