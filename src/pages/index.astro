---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const CAT_ICON = { business:'briefcase', personal:'user', travel:'map-pin', home:'home', event:'gift', finance:'dollar', health:'heart', seo:'trending' };

const templates = (await getCollection('templates')).sort((a,b)=>+b.data.updatedDate - +a.data.updatedDate);
const featured = templates.filter(t=>t.data.featured).slice(0,3);
const posts = (await getCollection('blog')).filter(p=>!p.data.draft).sort((a,b)=>+b.data.pubDate - +a.data.pubDate).slice(0,3);

const features = [
  {ic:'maker',t:'Online checklist maker',p:'Build your own checklist template online — add tasks, sections and colors.'},
  {ic:'download',t:'PDF & JPG download',p:'Download every checklist as a printable PDF or a high-quality image.'},
  {ic:'template',t:'Ready-made templates',p:'Professionally designed checklists for work, home, travel and more.'},
  {ic:'book',t:'Helpful blog',p:'Guides and tips to help you get organized and stay productive.'},
  {ic:'smartphone',t:'Fully responsive',p:'Looks and works beautifully on mobile, tablet and desktop.'},
  {ic:'zap',t:'Fast & SEO-ready',p:'Built for speed and search visibility from day one.'},
];
const steps = [
  {t:'Open the maker',p:'Go to the online checklist template maker — no login needed.'},
  {t:'Add your tasks',p:'Type your title and tasks, add sections and pick a color.'},
  {t:'Download PDF or JPG',p:'Export your checklist and print it or share the image.'},
];
---
<BaseLayout title="Checklist Template Maker Online — Create & Download Free Checklists (PDF & JPG)" description="Free checklist template maker online. Create your own checklist in your browser, choose colors, and download it as a PDF or JPG. Plus dozens of ready-made checklist templates.">

  <section class="hero" style="padding-top:80px;">
    <span class="blob b1"></span><span class="blob b2"></span>
    <div class="container hero-grid">
      <div>
        <span class="eyebrow anim-up" data-i18n="hero_badge">Free · No login · SEO-ready</span>
        <h1 class="anim-up a2" style="margin-top:14px;" data-i18n="hero_title">Checklist Template Maker — Online &amp; Free</h1>
        <p class="lead anim-up a3" data-i18n="hero_lead">Create your own checklist template online in seconds, or download ready-made ones. Add your tasks, pick a color, and export as a clean PDF or JPG.</p>
        <div class="cta anim-up a4">
          <a href="/maker" class="btn btn-primary"><Icon name="maker" size={18} /> <span data-i18n="hero_browse">Make a Checklist</span></a>
          <a href="/templates" class="btn btn-ghost"><Icon name="template" size={18} /> <span data-i18n="hero_how">Browse templates</span></a>
        </div>
        <p class="note anim-up a4" data-i18n="hero_note">Free forever · No sign-up · PDF &amp; JPG</p>
      </div>
      <div class="mock" aria-hidden="true">
        <div class="mtitle"><b><Icon name="map-pin" size={18} class="acc" /> Travel Packing</b><span class="muted" style="font-size:13px;">3 / 5 done</span></div>
        <div class="mbar"><i></i></div>
        <div class="mrow done"><span class="mck on"><Icon name="check" size={13} sw={3} /></span><span>Passport &amp; tickets</span></div>
        <div class="mrow done"><span class="mck on"><Icon name="check" size={13} sw={3} /></span><span>Phone charger</span></div>
        <div class="mrow done"><span class="mck on"><Icon name="check" size={13} sw={3} /></span><span>Toiletries</span></div>
        <div class="mrow"><span class="mck"></span><span>Sunglasses</span><span class="pill md">Medium</span></div>
        <div class="mrow"><span class="mck"></span><span>Travel adapter</span><span class="pill hi">High</span></div>
      </div>
    </div>
  </section>

  <section style="padding:36px 0;">
    <div class="container">
      <div class="stats reveal">
        <div class="stat"><b>50+</b><span data-i18n="stat_templates">Templates</span></div>
        <div class="stat"><b>2</b><span data-i18n="stat_formats">Formats (PDF &amp; JPG)</span></div>
        <div class="stat"><b>100%</b><span data-i18n="stat_free">Free</span></div>
        <div class="stat"><b>0</b><span data-i18n="stat_login">Login needed</span></div>
      </div>
    </div>
  </section>

  <section id="how" style="background:var(--soft);">
    <div class="container">
      <div class="sec-head reveal"><span class="eyebrow" data-i18n="how_eyebrow">How it works</span><h2 data-i18n="how_title">Make a checklist online in 3 steps</h2><p data-i18n="how_sub">Simple, fast, and completely free.</p></div>
      <div class="steps">
        {steps.map((s,i)=>(<div class={`step reveal d${i+1}`}><div class="n">{i+1}</div><h3>{s.t}</h3><p>{s.p}</p></div>))}
      </div>
      <div class="center" style="margin-top:34px;"><a href="/maker" class="btn btn-primary"><Icon name="maker" size={18} /> <span data-i18n="how_cta">Open the Checklist Maker</span></a></div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="sec-head reveal"><span class="eyebrow" data-i18n="feat_eyebrow">Features</span><h2 data-i18n="feat_title">Everything you need to stay organized</h2><p data-i18n="feat_sub">A powerful online checklist maker plus beautiful ready-made templates.</p></div>
      <div class="grid g-3">
        {features.map((f,i) => (<div class={`card feat reveal d${(i%3)+1}`}><div class="ic"><Icon name={f.ic} size={21} /></div><h3>{f.t}</h3><p>{f.p}</p></div>))}
      </div>
    </div>
  </section>

  <section style="background:var(--soft);">
    <div class="container">
      <div class="sec-head reveal"><span class="eyebrow" data-i18n="tpl_eyebrow">Templates</span><h2 data-i18n="tpl_title">Popular checklist templates</h2><p data-i18n="tpl_sub">Hand-picked templates loved by our users.</p></div>
      <div class="grid g-3">
        {featured.map((t,i) => (
          <a href={`/templates/${t.slug}`} class={`card tpl reveal d${(i%3)+1}`}>
            <div class="tpl-ic"><Icon name={CAT_ICON[t.data.category] || 'template'} size={22} /></div>
            <h3>{t.data.title}</h3>
            <p>{t.data.description}</p>
            <div class="meta"><span class="badge">{t.data.category}</span><span>{t.data.items} items →</span></div>
          </a>
        ))}
      </div>
      <div class="center" style="margin-top:36px;"><a href="/templates" class="btn btn-ghost"><span data-i18n="tpl_viewall">View all templates</span></a></div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="sec-head reveal"><span class="eyebrow" data-i18n="blog_eyebrow">Blog</span><h2 data-i18n="blog_title">From the blog</h2><p data-i18n="blog_sub">Tips and guides to help you get more done.</p></div>
      <div class="grid g-3">
        {posts.map((p,i) => (
          <a href={`/blog/${p.slug}`} class={`card post reveal d${(i%3)+1}`}>
            <div class="cover"><Icon name="book" size={40} /></div>
            <div class="body"><h3>{p.data.title}</h3><p>{p.data.description}</p><div class="date">{p.data.pubDate.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</div></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="band reveal">
        <h2 data-i18n="cta_title">Ready to make your checklist?</h2>
        <p data-i18n="cta_sub">Use the free online checklist template maker — build it, download it, done.</p>
        <a href="/maker" class="btn btn-primary"><Icon name="maker" size={18} /> <span data-i18n="cta_btn">Make a Checklist</span></a>
      </div>
    </div>
  </section>

  <style>
    .tpl-ic{width:46px;height:46px;border-radius:12px;background:var(--icon-chip);color:var(--blue);display:flex;align-items:center;justify-content:center;margin-bottom:4px;}
    .mtitle .acc{color:var(--blue);}
    .post .cover{color:#fff;}
  </style>
</BaseLayout>
