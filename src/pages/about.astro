---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Checklist" description="Learn about Checklist — our mission to help you organize your life and work with beautiful, free checklist templates.">
  <section style="padding-top:56px;">
    <div class="container">
      <div class="prose">
        <span class="eyebrow">About us</span>
        <h1 style="font-size:38px;font-weight:800;margin-top:10px;">We make getting organized simple</h1>
        <p>Checklist is a free library of professionally designed checklist templates for work, home, travel and everything in between. Our goal is simple: help you remember what matters and finish what you start.</p>
        <h2>Why we built this</h2>
        <p>Great checklists reduce stress and prevent mistakes — but most people don't have time to build them from scratch. So we did it for you. Every template is crafted to be clear, printable and instantly usable.</p>
        <h2>What you get</h2>
        <ul>
          <li>Free, downloadable checklist templates (PDF)</li>
          <li>New templates added regularly</li>
          <li>A blog full of productivity tips</li>
        </ul>
        <p>Have a template request? We'd love to hear it.</p>
      </div>
    </div>
  </section>
</BaseLayout>
