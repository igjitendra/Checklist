---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).filter(p=>!p.data.draft).sort((a,b)=>+b.data.pubDate - +a.data.pubDate);
---
<BaseLayout title="Blog — Productivity Tips & Checklist Guides" description="Guides, tips and how-tos on productivity, organization and getting things done with checklists.">
  <section style="padding-top:56px;">
    <div class="container">
      <div class="sec-head"><span class="eyebrow">Blog</span><h2>Tips & guides to get things done</h2><p>Practical advice on productivity, organization and checklists.</p></div>
      <div class="grid g-3">
        {posts.map(p => (
          <a href={`/blog/${p.slug}`} class="card post">
            <div class="cover">{p.data.emoji}</div>
            <div class="body"><h3>{p.data.title}</h3><p>{p.data.description}</p><div class="date">{p.data.pubDate.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</div></div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
