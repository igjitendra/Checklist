---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found — Checklist" description="The page you are looking for could not be found." noindex={true}>
  <section style="padding:100px 0;text-align:center;">
    <div class="container">
      <div style="font-size:64px;">🧭</div>
      <h1 style="font-size:34px;font-weight:800;margin:16px 0 8px;">Page not found</h1>
      <p class="muted" style="margin-bottom:24px;">The page you're looking for doesn't exist or was moved.</p>
      <a href="/" class="btn btn-primary">Back to home</a>
    </div>
  </section>
</BaseLayout>
