---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DownloadForm from '../../components/DownloadForm.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const templates = await getCollection('templates');
  return templates.map(t => ({ params: { slug: t.slug }, props: { t } }));
}
const { t } = Astro.props;
const { Content } = await t.render();
---
<BaseLayout
  title={`${t.data.title} — Free Checklist Template (PDF & JPG)`}
  description={t.data.description}
  image={t.data.preview}
  type="article"
  publishedTime={t.data.updatedDate.toISOString()}
>
  <section style="padding-top:48px;">
    <div class="container">
      <div class="tpl-detail" style="display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:start;">
        <div>
          <a href="/templates" class="muted" style="font-size:14px;">← All templates</a>
          <div style="font-size:44px;margin:14px 0 6px;">{t.data.emoji}</div>
          <h1 style="font-size:34px;font-weight:800;">{t.data.title} {t.data.pro && <span class="pro-tag">PRO</span>}</h1>
          <p class="muted" style="font-size:17px;margin:12px 0 16px;max-width:560px;">{t.data.description}</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;">
            <span class="badge">{t.data.category}</span>
            <span class="badge">{t.data.items} items</span>
            {t.data.formats.map(f => <span class="badge">{f.toUpperCase()}</span>)}
          </div>
          <div class="preview-shot">
            <img src={t.data.preview} alt={`${t.data.title} preview`} loading="lazy" width="720" height="1018" />
            <span class="pv-badge">Preview · download for full quality</span>
          </div>
          <div class="prose" style="margin-top:28px;"><Content /></div>
        </div>
        <div style="position:sticky;top:88px;">
          <DownloadForm fileBase={t.data.fileBase} templateTitle={t.data.title} formats={t.data.formats} pro={t.data.pro} />
        </div>
      </div>
    </div>
  </section>
  <style>
    .preview-shot{position:relative;border:1px solid var(--border);border-radius:12px;overflow:hidden;background:var(--soft);box-shadow:var(--shadow);max-width:460px;}
    .preview-shot img{width:100%;height:auto;display:block;}
    .pv-badge{position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,.65);color:#fff;font-size:11px;font-weight:600;padding:4px 10px;border-radius:99px;}
    .pro-tag{font-size:13px;font-weight:800;color:#a35e1f;background:#FBEBDE;padding:3px 10px;border-radius:99px;vertical-align:middle;}
    @media(max-width:820px){.tpl-detail{grid-template-columns:1fr !important;}}
  </style>
</BaseLayout>
