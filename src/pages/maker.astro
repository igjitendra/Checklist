---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const faqs = [
  { q: 'What is a checklist template maker online?', a: 'It is a free online tool that lets you create your own custom checklist template in your browser — add sections and tasks, pick a color, font and layout, and download it as a PDF or JPG. No sign-up or software needed.' },
  { q: 'Is this checklist maker free?', a: 'Yes. You can build unlimited checklist templates online and download them free as PDF or JPG.' },
  { q: 'Can I add sections and numbered tasks?', a: 'Yes — group tasks into sections, show numbers, and every task has a checkbox on the left.' },
  { q: 'Do I need an account to make a checklist?', a: 'No account or login is required. Your checklist is created in your browser and saved locally.' },
];
const faqJsonLd = { '@context':'https://schema.org','@type':'FAQPage', mainEntity: faqs.map(f=>({'@type':'Question',name:f.q,acceptedAnswer:{'@type':'Answer',text:f.a}})) };
---
<BaseLayout
  title="Checklist Template Maker Online — Create & Download Free (PDF & JPG)"
  description="Free online checklist template maker. Create your own checklist with sections, numbered tasks and checkboxes. Choose colors, fonts and layout, and download as PDF or JPG."
>
  <section style="padding-top:44px;padding-bottom:16px;">
    <div class="container">
      <div class="center" style="max-width:720px;margin:0 auto;">
        <span class="eyebrow">Free online tool</span>
        <h1 style="font-size:38px;font-weight:800;margin-top:10px;">Checklist Template Maker Online</h1>
        <p class="muted" style="font-size:18px;margin-top:12px;">Create your own checklist with <strong>sections, numbered tasks &amp; checkboxes</strong>. Pick a color, font &amp; layout, then download free as <strong>PDF</strong> or <strong>JPG</strong>.</p>
      </div>
    </div>
  </section>

  <section style="padding-top:8px;">
    <div class="container">
      <div class="maker">
        <div class="editor no-print">
          <div class="ed-card">
            <h2 class="ed-h"><Icon name="maker" size={18} /> Build your checklist</h2>
            <div class="field"><label>Title</label><input id="mkTitle" type="text" value="Branding" /></div>
            <div class="field"><label>Subtitle</label><input id="mkSub" type="text" value="Checklist" /></div>
            <div class="field"><label>Accent color</label><div class="swatches" id="mkSwatches"></div></div>
            <div class="field"><label>Font style</label>
              <div class="seg-opts" id="mkFonts">
                <button type="button" data-font="sans">Modern</button>
                <button type="button" data-font="serif">Elegant</button>
                <button type="button" data-font="rounded">Rounded</button>
                <button type="button" data-font="hand">Handwritten</button>
              </div>
            </div>
            <div class="field"><label>Layout</label>
              <div class="seg-opts" id="mkLayout">
                <button type="button" data-layout="one">One column</button>
                <button type="button" data-layout="two">Two columns</button>
              </div>
            </div>
            <label class="mk-toggle"><input type="checkbox" id="mkNumbered" checked /> Show numbers before tasks</label>

            <div class="field" style="margin-top:12px;"><label>Sections &amp; tasks</label>
              <div id="mkSections"></div>
              <button class="add-sec-btn" id="mkAddSection" type="button"><span class="pi"></span> Add section</button>
            </div>

            <div class="field"><label>Footer / brand text</label><input id="mkFooter" type="text" value="checklist" /></div>

            <div style="display:flex;gap:10px;margin-top:8px;">
              <button class="btn btn-ghost" id="mkPdf" type="button"><Icon name="printer" size={17} /> Download PDF</button>
              <button class="btn btn-primary" id="mkJpg" type="button"><Icon name="image" size={17} /> Download JPG</button>
            </div>
            <p class="muted" style="font-size:12px;margin-top:10px;display:flex;align-items:center;gap:6px;"><Icon name="lock" size={13} /> Saved automatically in your browser.</p>
          </div>
        </div>

        <div class="preview-col">
          <div class="sheet" id="mkSheet" data-font="sans" data-layout="one">
            <div class="sh-title" id="shTitle">Branding</div>
            <div class="sh-sub" id="shSub">Checklist</div>
            <div class="sh-underline" id="shUnderline"></div>
            <div id="shBody"></div>
            <div class="sh-footer" id="shFooter">checklist</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--soft);">
    <div class="container"><div class="prose reveal">
      <h2>The easiest checklist template maker online</h2>
      <p>Our free <strong>checklist template maker online</strong> lets you design a clean, professional checklist in seconds. Group tasks into sections, show numbers, pick colors, fonts and a one- or two-column layout, then download as a printable PDF or a high-quality JPG image — no login required.</p>
      <p>Prefer a head start? Browse our <a href="/templates">ready-made checklist templates</a>.</p>
    </div></div>
  </section>

  <section>
    <div class="container">
      <div class="sec-head reveal"><span class="eyebrow">FAQ</span><h2>Checklist maker — questions</h2></div>
      <div style="max-width:760px;margin:0 auto;">{faqs.map(f => (<details class="faq reveal"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Kalam:wght@700&display=swap');
    .maker{display:grid;grid-template-columns:410px 1fr;gap:36px;align-items:start;}
    @media(max-width:880px){.maker{grid-template-columns:1fr;}}
    .editor{position:sticky;top:84px;} @media(max-width:880px){.editor{position:static;}}
    .ed-card{background:var(--canvas);border:1px solid var(--border);border-radius:14px;padding:22px;box-shadow:var(--shadow);}
    .ed-h{font-size:16px;font-weight:800;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
    .ed-card .field{margin-bottom:14px;} .ed-card label{display:block;font-size:13px;font-weight:600;margin-bottom:6px;}
    .ed-card input[type=text]{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:15px;font-family:inherit;background:var(--soft);outline:none;color:var(--ink);}
    .ed-card input[type=text]:focus{border-color:var(--blue);}
    .swatches{display:flex;gap:8px;flex-wrap:wrap;} .sw{width:30px;height:30px;border-radius:50%;cursor:pointer;border:2px solid var(--canvas);box-shadow:0 0 0 1px var(--border);} .sw.active{box-shadow:0 0 0 2px var(--ink);}
    .seg-opts{display:flex;gap:6px;flex-wrap:wrap;} .seg-opts button{padding:8px 12px;border:1px solid var(--border);border-radius:8px;background:var(--soft);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;color:var(--muted);} .seg-opts button.active{border-color:var(--blue);background:var(--blue-soft);color:var(--blue-dark);}
    .mk-item{display:flex;align-items:center;gap:6px;margin-bottom:6px;} .mk-item input{flex:1;padding:8px 10px;border:1px solid var(--border);border-radius:7px;font-size:14px;font-family:inherit;background:var(--canvas);color:var(--ink);} .mk-item button{border:none;background:none;cursor:pointer;color:var(--muted);padding:5px;border-radius:6px;display:flex;} .mk-item button:hover{background:var(--surface);color:var(--ink);}
    .add-item-btn{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--blue);background:none;border:none;cursor:pointer;padding:6px 2px;font-family:inherit;}

    .preview-col{display:flex;justify-content:center;}
    .sheet{background:#fff;border:1px solid var(--border);border-radius:10px;box-shadow:var(--shadow);width:100%;max-width:520px;aspect-ratio:1/1.414;padding:50px 52px;display:flex;flex-direction:column;overflow:hidden;}
    .sheet[data-font=sans]{font-family:system-ui,Arial,sans-serif;} .sheet[data-font=serif]{font-family:Georgia,'Times New Roman',serif;} .sheet[data-font=rounded]{font-family:'Trebuchet MS','Segoe UI',sans-serif;} .sheet[data-font=hand]{font-family:'Caveat','Kalam',cursive;}
    .sh-title{text-align:center;font-size:50px;font-weight:800;letter-spacing:-1px;color:#222;line-height:1;word-break:break-word;}
    .sh-sub{text-align:center;font-family:'Caveat','Kalam',cursive;font-size:46px;font-weight:700;color:#222;margin-top:0;line-height:1;}
    .sh-underline{width:150px;height:7px;border-radius:4px;margin:14px auto 26px;}
    #shBody{flex:1;}
    @media print{.nav,.footer,.editor,.no-print,.eyebrow,.prose,.sec-head,.faq,section+section{display:none !important;}.sheet{box-shadow:none;border:none;max-width:none;}@page{size:A4;margin:14mm;}}
  </style>

  <script>
    const $ = (s) => document.querySelector(s);
    const LS = 'checklist_maker_v3';
    const COLORS = ['#F0872C','#2783DE','#46A171','#E56458','#7C4DD1','#111111'];
    const FONTS = { sans:'system-ui,Arial,sans-serif', serif:"Georgia,'Times New Roman',serif", rounded:"'Trebuchet MS','Segoe UI',sans-serif", hand:"'Caveat','Kalam',cursive" };
    const IC_TRASH = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
    const IC_UP = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>';
    const IC_PLUS = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>';

    let state = { title:'Branding', sub:'Checklist', accent:'#F0872C', footer:'checklist', font:'sans', layout:'one', numbered:true,
      sections:[ {title:'Identity', items:['Logo design','Brand colors','Typography','Brand voice']},
                 {title:'Assets', items:['Business cards','Website design','Email signature','Social media handles']} ] };

    function save(){ try{ localStorage.setItem(LS, JSON.stringify(state)); }catch(e){} }
    function load(){ try{ const d=JSON.parse(localStorage.getItem(LS)); if(d&&d.sections) state=Object.assign(state,d); }catch(e){} }

    function renderSwatches(){ const w=$('#mkSwatches'); w.innerHTML=''; COLORS.forEach(c=>{ const s=document.createElement('div'); s.className='sw'+(c===state.accent?' active':''); s.style.background=c; s.onclick=()=>{ state.accent=c; save(); renderAll(); }; w.appendChild(s); }); }
    function renderSegs(){ document.querySelectorAll('#mkFonts button').forEach(b=>b.classList.toggle('active',b.dataset.font===state.font)); document.querySelectorAll('#mkLayout button').forEach(b=>b.classList.toggle('active',b.dataset.layout===state.layout)); $('#mkNumbered').checked=state.numbered; }

    function renderSections(){
      const box=$('#mkSections'); box.innerHTML='';
      state.sections.forEach((sec,si)=>{
        const wrap=document.createElement('div'); wrap.className='mk-section';
        const head=document.createElement('div'); head.className='mk-section-head';
        const ti=document.createElement('input'); ti.type='text'; ti.value=sec.title; ti.placeholder='Section title (optional)';
        ti.oninput=()=>{ sec.title=ti.value; save(); renderSheet(); };
        const delS=document.createElement('button'); delS.className='del-sec'; delS.innerHTML=IC_TRASH; delS.title='Delete section';
        delS.onclick=()=>{ state.sections.splice(si,1); if(!state.sections.length) state.sections.push({title:'',items:[]}); save(); renderSections(); renderSheet(); };
        head.append(ti,delS); wrap.appendChild(head);
        sec.items.forEach((it,ii)=>{
          const row=document.createElement('div'); row.className='mk-item';
          const inp=document.createElement('input'); inp.type='text'; inp.value=it; inp.oninput=()=>{ sec.items[ii]=inp.value; save(); renderSheet(); };
          const up=document.createElement('button'); up.innerHTML=IC_UP; up.title='Move up'; up.onclick=()=>{ if(ii>0){ [sec.items[ii-1],sec.items[ii]]=[sec.items[ii],sec.items[ii-1]]; save(); renderSections(); renderSheet(); } };
          const del=document.createElement('button'); del.innerHTML=IC_TRASH; del.title='Delete'; del.onclick=()=>{ sec.items.splice(ii,1); save(); renderSections(); renderSheet(); };
          row.append(inp,up,del); wrap.appendChild(row);
        });
        const add=document.createElement('button'); add.className='add-item-btn'; add.innerHTML=IC_PLUS+' Add task';
        add.onclick=()=>{ sec.items.push('New task'); save(); renderSections(); renderSheet(); };
        wrap.appendChild(add);
        box.appendChild(wrap);
      });
    }

    function renderSheet(){
      const sh=$('#mkSheet'); sh.dataset.font=state.font; sh.dataset.layout=state.layout; sh.style.setProperty('--mk-accent', state.accent);
      $('#shTitle').textContent=state.title; $('#shSub').textContent=state.sub; $('#shSub').style.display=state.sub?'block':'none';
      $('#shUnderline').style.background=state.accent; $('#shFooter').textContent=state.footer;
      const body=$('#shBody'); body.innerHTML='';
      state.sections.forEach(sec=>{
        const s=document.createElement('div'); s.className='sh-section';
        if(sec.title){ const h=document.createElement('div'); h.className='sh-section-title'; h.innerHTML='<span class="bar"></span>'; const sp=document.createElement('span'); sp.textContent=sec.title; h.appendChild(sp); s.appendChild(h); }
        const ul=document.createElement('ul'); ul.className='sh-list';
        sec.items.forEach((it,i)=>{ const li=document.createElement('li'); const b=document.createElement('span'); b.className='box'; li.appendChild(b); if(state.numbered){ const n=document.createElement('span'); n.className='num'; n.textContent=(i+1)+'.'; li.appendChild(n);} const t=document.createElement('span'); t.textContent=it; li.appendChild(t); ul.appendChild(li); });
        s.appendChild(ul); body.appendChild(s);
      });
    }
    function renderAll(){ renderSwatches(); renderSegs(); renderSections(); renderSheet(); $('#mkTitle').value=state.title; $('#mkSub').value=state.sub; $('#mkFooter').value=state.footer; }

    async function downloadJPG(){
      const W=1000,H=1414,c=document.createElement('canvas'); c.width=W;c.height=H; const x=c.getContext('2d'); const fam=FONTS[state.font];
      try{ await document.fonts.load(`700 90px 'Caveat'`); if(state.font==='hand'){ await document.fonts.load(`700 90px 'Kalam'`); } await document.fonts.ready; }catch(e){}
      x.fillStyle='#fff'; x.fillRect(0,0,W,H);
      x.textAlign='center'; x.fillStyle='#222'; x.font=`800 90px ${fam}`; x.fillText(state.title||'', W/2, 140);
      if(state.sub){ x.font=`700 72px 'Caveat', cursive`; x.fillText(state.sub, W/2, 218); }
      x.strokeStyle=state.accent; x.lineWidth=11; x.lineCap='round'; x.beginPath(); x.moveTo(W/2-140,258); x.lineTo(W/2+140,264); x.stroke();
      const two=state.layout==='two';
      let rows=0; state.sections.forEach(s=>{ rows+=(s.title?1:0)+(two?Math.ceil(s.items.length/2):s.items.length); });
      const gap=Math.max(34, Math.min((H-560)/Math.max(rows,1), 60));
      let y=350;
      const drawItem=(it,idx,px,py)=>{ x.strokeStyle=state.accent; x.lineWidth=3; x.strokeRect(px,py-24,30,30); let tx=px+44; x.textAlign='left';
        if(state.numbered){ x.fillStyle=state.accent; x.font=`800 34px ${fam}`; const nn=(idx+1)+'.'; x.fillText(nn,tx,py); tx+=x.measureText(nn).width+14; }
        x.fillStyle='#222'; x.font=`400 34px ${fam}`; let t=it||''; const maxC=two?20:38; if(t.length>maxC) t=t.slice(0,maxC-1)+'\u2026'; x.fillText(t,tx,py); };
      state.sections.forEach(sec=>{
        if(sec.title){ x.textAlign='left'; x.fillStyle='#222'; x.font=`800 38px ${fam}`; x.fillText(sec.title, 80, y+4); y+=gap; }
        if(two){ const half=Math.ceil(sec.items.length/2);
          for(let i=0;i<half;i++){ drawItem(sec.items[i],i,90,y); if(sec.items[i+half]!==undefined) drawItem(sec.items[i+half],i+half,540,y); y+=gap; } }
        else { sec.items.forEach((it,i)=>{ drawItem(it,i,90,y); y+=gap; }); }
        y+=8;
      });
      x.textAlign='center'; x.fillStyle='#8a8a8a'; x.font=`700 30px ${fam}`; x.fillText((state.footer||'').toUpperCase(), W/2, H-46);
      const a=document.createElement('a'); a.href=c.toDataURL('image/jpeg',0.95); a.download=(state.title||'checklist').toLowerCase().replace(/[^a-z0-9]+/g,'-')+'-checklist.jpg'; a.click();
    }

    document.addEventListener('DOMContentLoaded', ()=>{
      load(); renderAll();
      $('#mkTitle').oninput=e=>{ state.title=e.target.value; save(); renderSheet(); };
      $('#mkSub').oninput=e=>{ state.sub=e.target.value; save(); renderSheet(); };
      $('#mkFooter').oninput=e=>{ state.footer=e.target.value; save(); renderSheet(); };
      $('#mkNumbered').onchange=e=>{ state.numbered=e.target.checked; save(); renderSheet(); };
      document.querySelectorAll('#mkFonts button').forEach(b=>b.onclick=()=>{ state.font=b.dataset.font; save(); renderSegs(); renderSheet(); });
      document.querySelectorAll('#mkLayout button').forEach(b=>b.onclick=()=>{ state.layout=b.dataset.layout; save(); renderSegs(); renderSheet(); });
      $('#mkAddSection').onclick=()=>{ state.sections.push({title:'New section', items:['New task']}); save(); renderSections(); renderSheet(); };
      $('#mkPdf').onclick=()=>window.print();
      $('#mkJpg').onclick=downloadJPG;
    });
  </script>
</BaseLayout>
