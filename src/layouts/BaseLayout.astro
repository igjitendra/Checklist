          es:{nav_templates:'Plantillas',nav_blog:'Blog',nav_maker:'Creador de plantillas',nav_make:'Crear lista',hero_title:'Creador de plantillas de listas — en línea y gratis',hero_lead:'Crea tu propia lista de verificación en segundos o descarga plantillas listas. Añade tareas, elige un color y expórtala en PDF o JPG.',hero_browse:'Crear lista',hero_how:'Ver plantillas',hero_note:'Gratis · Sin registro · PDF y JPG',stat_templates:'Plantillas',stat_formats:'Formatos (PDF y JPG)',stat_free:'Gratis',stat_login:'Sin registro',how_cta:'Abrir el creador',tpl_viewall:'Ver todas',cta_title:'¿Listo para crear tu lista?',cta_sub:'Usa el creador de listas gratis en línea.',cta_btn:'Crear lista',foot_product:'Producto',foot_categories:'Categorías',foot_legal:'Legal',foot_about:'Acerca de'},
          fr:{nav_templates:'Modèles',nav_blog:'Blog',nav_maker:'Créateur de modèles',nav_make:'Créer une liste',hero_title:'Créateur de modèles de listes — en ligne et gratuit',hero_lead:'Créez votre liste de contrôle en quelques secondes ou téléchargez des modèles. Ajoutez des tâches, choisissez une couleur et exportez en PDF ou JPG.',hero_browse:'Créer une liste',hero_how:'Voir les modèles',hero_note:'Gratuit · Sans compte · PDF et JPG',stat_templates:'Modèles',stat_formats:'Formats (PDF et JPG)',stat_free:'Gratuit',stat_login:'Sans compte',how_cta:'Ouvrir le créateur',tpl_viewall:'Voir tout',cta_title:'Prêt à créer votre liste ?',cta_sub:'Utilisez le créateur de listes gratuit en ligne.',cta_btn:'Créer une liste',foot_product:'Produit',foot_categories:'Catégories',foot_legal:'Légal',foot_about:'À propos'},
          pt:{nav_templates:'Modelos',nav_blog:'Blog',nav_maker:'Criador de modelos',nav_make:'Criar lista',hero_title:'Criador de modelos de listas — online e grátis',hero_lead:'Crie sua própria lista de verificação em segundos ou baixe modelos prontos. Adicione tarefas, escolha uma cor e exporte em PDF ou JPG.',hero_browse:'Criar lista',hero_how:'Ver modelos',hero_note:'Grátis · Sem cadastro · PDF e JPG',stat_templates:'Modelos',stat_formats:'Formatos (PDF e JPG)',stat_free:'Grátis',stat_login:'Sem login',how_cta:'Abrir o criador',tpl_viewall:'Ver todos',cta_title:'Pronto para criar sua lista?',cta_sub:'Use o criador de listas grátis online.',cta_btn:'Criar lista',foot_product:'Produto',foot_categories:'Categorias',foot_legal:'Legal',foot_about:'Sobre'},
          de:{nav_templates:'Vorlagen',nav_blog:'Blog',nav_maker:'Vorlagen-Ersteller',nav_make:'Checkliste erstellen',hero_title:'Checklisten-Vorlagen-Ersteller — Online & kostenlos',hero_lead:'Erstellen Sie Ihre eigene Checkliste in Sekunden oder laden Sie fertige Vorlagen herunter. Aufgaben hinzufügen, Farbe wählen und als PDF oder JPG exportieren.',hero_browse:'Checkliste erstellen',hero_how:'Vorlagen ansehen',hero_note:'Kostenlos · Ohne Anmeldung · PDF & JPG',stat_templates:'Vorlagen',stat_formats:'Formate (PDF & JPG)',stat_free:'Kostenlos',stat_login:'Kein Login',how_cta:'Ersteller öffnen',tpl_viewall:'Alle ansehen',cta_title:'Bereit für Ihre Checkliste?',cta_sub:'Nutzen Sie den kostenlosen Online-Ersteller.',cta_btn:'Checkliste erstellen',foot_product:'Produkt',foot_categories:'Kategorien',foot_legal:'Rechtliches',foot_about:'Über uns'},
          ar:{nav_templates:'القوالب',nav_blog:'المدونة',nav_maker:'منشئ القوالب',nav_make:'إنشاء قائمة',hero_title:'منشئ قوالب قوائم التحقق — عبر الإنترنت ومجاني',hero_lead:'أنشئ قائمة التحقق الخاصة بك في ثوانٍ أو نزّل قوالب جاهزة. أضف المهام واختر لونًا وصدّرها بصيغة PDF أو JPG.',hero_browse:'إنشاء قائمة',hero_how:'تصفح القوالب',hero_note:'مجاني · بدون تسجيل · PDF و JPG',stat_templates:'القوالب',stat_formats:'الصيغ (PDF و JPG)',stat_free:'مجاني',stat_login:'بدون تسجيل',how_cta:'افتح المنشئ',tpl_viewall:'عرض الكل',cta_title:'هل أنت مستعد لإنشاء قائمتك؟',cta_sub:'استخدم منشئ القوائم المجاني عبر الإنترنت.',cta_btn:'إنشاء قائمة',foot_product:'المنتج',foot_categories:'الفئات',foot_legal:'قانوني',foot_about:'من نحن'},
          zh:{nav_templates:'模板',nav_blog:'博客',nav_maker:'模板生成器',nav_make:'创建清单',hero_title:'清单模板生成器 — 在线且免费',hero_lead:'几秒钟创建你自己的清单，或下载现成模板。添加任务、选择颜色，并导出为 PDF 或 JPG。',hero_browse:'创建清单',hero_how:'浏览模板',hero_note:'永久免费 · 无需注册 · PDF 和 JPG',stat_templates:'模板',stat_formats:'格式（PDF 和 JPG）',stat_free:'免费',stat_login:'无需登录',how_cta:'打开生成器',tpl_viewall:'查看全部',cta_title:'准备好创建你的清单了吗？',cta_sub:'使用免费的在线清单生成器。',cta_btn:'创建清单',foot_product:'产品',foot_categories:'分类',foot_legal:'法律',foot_about:'关于'}
        };
        var LANGS = [['en','English'],['hi','हिन्दी'],['bn','বাংলা'],['ta','தமிழ்'],['es','Español'],['fr','Français'],['pt','Português'],['de','Deutsch'],['ar','العربية'],['zh','中文']];
        var RTL = {ar:1};
        function detect(){ try{ var s=localStorage.getItem('lang'); if(s) return s; }catch(e){} var n=(navigator.language||'en').slice(0,2).toLowerCase(); return DICT[n]?n:'en'; }
        window.__lang = 'en';
        window.__t = function(k,f){ var d=DICT[window.__lang]||DICT.en; return (d[k]!=null?d[k]:(DICT.en[k]!=null?DICT.en[k]:(f||k))); };
        function apply(lang){
          window.__lang = lang; var d=DICT[lang]||DICT.en;
          document.querySelectorAll('[data-i18n]').forEach(function(el){ var k=el.getAttribute('data-i18n'); var v=(d[k]!=null?d[k]:DICT.en[k]); if(v!=null) el.textContent=v; });
          document.querySelectorAll('[data-i18n-ph]').forEach(function(el){ var k=el.getAttribute('data-i18n-ph'); var v=(d[k]!=null?d[k]:DICT.en[k]); if(v!=null) el.setAttribute('placeholder',v); });
          document.documentElement.lang=lang; document.documentElement.dir = RTL[lang]?'rtl':'ltr';
          try{localStorage.setItem('lang',lang);}catch(e){}
          document.dispatchEvent(new CustomEvent('langchange'));
        }
        var cur=detect();
        var sel=document.getElementById('langSelect');
        if(sel){ sel.innerHTML=LANGS.map(function(l){return '<option value="'+l[0]+'"'+(l[0]===cur?' selected':'')+'>'+l[1]+'</option>';}).join(''); sel.addEventListener('change',function(){apply(sel.value);}); }
        apply(cur);

        var els=document.querySelectorAll('.reveal');
        if(!('IntersectionObserver' in window)||!els.length){ els.forEach(function(e){e.classList.add('in');}); }
        else { var io=new IntersectionObserver(function(en){en.forEach(function(x){ if(x.isIntersecting){x.target.classList.add('in'); io.unobserve(x.target);} });},{threshold:.12,rootMargin:'0px 0px -40px 0px'}); els.forEach(function(e){io.observe(e);}); }
      })();
    </script>
